          "name": "Créer véhicule",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hospitalId\": \"{{hospitalId}}\",\n  \"vehicleTypeId\": \"{{vehicleTypeId}}\",\n  \"registration\": \"AB-123-CD\",\n  \"brand\": \"Renault\",\n  \"model\": \"Espace\",\n  \"year\": 2023\n}"
            },
            "url": "{{baseUrl}}/api/vehicles"
          }
        },
        {
          "name": "Détail véhicule",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}" }
        },
