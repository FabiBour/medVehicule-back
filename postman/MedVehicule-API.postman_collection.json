        },
        {
          "name": "Supprimer véhicule",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}" }
        },
        {
          "name": "Historique véhicule",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}/history",
            "description": "Prises, interventions et entretiens"
          }
        }
      ]
    },
    {
