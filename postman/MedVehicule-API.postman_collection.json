{
  "info": {
    "name": "MedVehicule API",
    "description": "API REST de gestion de flotte de véhicules hospitaliers.\n\nAuthentification : Firebase ID token dans Authorization Bearer.\nRôles : 0=usager, 1=gestionnaire, 2=admin, 3=super_admin.\n\nSwagger : https://medvehicule-back.onrender.com/api-docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://medvehicule-back.onrender.com" },
    { "key": "firebaseToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{firebaseToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Système",
      "item": [
        {
          "name": "Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Santé de l'API (sans auth)"
          }
        }
      ]
    },
    {
      "name": "Authentification",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{firebaseToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.idToken) {",
                  "    pm.environment.set('firebaseToken', json.idToken);",
                  "    pm.collectionVariables.set('firebaseToken', json.idToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Connexion avec email et mot de passe. Retourne idToken. Le script de test enregistre le token dans firebaseToken."
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.idToken) {",
                  "    pm.environment.set('firebaseToken', json.idToken);",
                  "    pm.collectionVariables.set('firebaseToken', json.idToken);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nouveau@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Jean\",\n  \"lastName\": \"Dupont\",\n  \"hospitalId\": null\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Création de compte. Retourne idToken si FIREBASE_WEB_API_KEY configuré. Le script enregistre le token dans firebaseToken."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Profil utilisateur courant. Requiert Bearer token Firebase valide ({{firebaseToken}})."
          }
        }
      ]
    },
    {
      "name": "Établissements",
      "item": [
        {
          "name": "Liste établissements",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/hospitals"
          }
        },
        {
          "name": "Créer établissement",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CHU Centre\",\n  \"address\": \"2 rue de l'Hôpital\"\n}"
            },
            "url": "{{baseUrl}}/api/hospitals"
          }
        },
        {
          "name": "Détail établissement",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/hospitals/{{hospitalId}}"
          }
        },
        {
          "name": "Modifier établissement",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CHU Centre Modifié\",\n  \"address\": \"3 rue Nouvelle\"\n}"
            },
            "url": "{{baseUrl}}/api/hospitals/{{hospitalId}}"
          }
        }
      ]
    },
    {
      "name": "Types de véhicules",
      "item": [
        {
          "name": "Liste types",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/vehicle-types" }
        },
        {
          "name": "Créer type",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Voiture\",\n  \"description\": \"Véhicule léger\"\n}"
            },
            "url": "{{baseUrl}}/api/vehicle-types"
          }
        },
        {
          "name": "Détail type",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/vehicle-types/{{vehicleTypeId}}" }
        },
        {
          "name": "Modifier type",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ambulance\",\n  \"description\": \"Véhicule sanitaire\"\n}" },
            "url": "{{baseUrl}}/api/vehicle-types/{{vehicleTypeId}}"
          }
        }
