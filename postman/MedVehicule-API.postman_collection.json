          "name": "Modifier véhicule",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registration\": \"CD-456-EF\",\n  \"brand\": \"Peugeot\",\n  \"model\": \"5008\",\n  \"year\": 2024,\n  \"vehicleTypeId\": \"{{vehicleTypeId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}"
