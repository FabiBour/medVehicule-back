    },
    {
      "name": "Véhicules",
      "item": [
        {
          "name": "Liste véhicules",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/vehicles?hospitalId=&vehicleTypeId=&available=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vehicles"],
              "query": [
                {"key": "hospitalId", "value": ""},
                {"key": "vehicleTypeId", "value": ""},
                {"key": "available", "value": "", "description": "true | false"}
