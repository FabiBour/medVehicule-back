        {
          "name": "Créer réservation",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"startDate\": \"2024-01-15T09:00:00.000Z\",\n  \"endDate\": null,\n  \"notes\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings"
          }
        },
