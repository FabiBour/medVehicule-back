# Port du serveur
PORT=3000

# Répertoire des uploads (photos, modèles 3D)
UPLOAD_DIR=./uploads

# Firebase / Firestore (Admin SDK - compte de service)
# Option 1 : Chemin vers le fichier JSON du compte de service Firebase
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Option 2 : JSON du compte de service en variable (pour déploiement)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Firebase Auth - Clé API Web (pour login via REST Identity Toolkit)
# OBLIGATOIRE pour POST /api/auth/login
# Format : AIzaSy... (PAS le private_key_id !)
# Firebase Console > Paramètres du projet > Général > Clés API Web
FIREBASE_WEB_API_KEY=AIzaSy...

